{
	"name": "DF_Silver_SUP_Entregas",
	"properties": {
		"folder": {
			"name": "bronze_to_silver/SUP"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_SUP_Entregas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_SUP_Entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(fecha_entrega = toDate(fecha_entrega, 'yyyy-MM-dd'),",
				"          fecha_proxima_entrega = toDate(fecha_proxima_entrega, 'yyyy-MM-dd'),",
				"          peso_paquete_kg = toDecimal(peso_paquete_kg),",
				"          lote_produccion = iifNull(lote_produccion, 'SIN LOTE')) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          entrega_id,",
				"          boleta_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          paquete_id,",
				"          paquete_nombre,",
				"          fecha_entrega,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(18,2),",
				"          fecha_proxima_entrega as date,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_id,",
				"          boleta_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          paquete_id,",
				"          paquete_nombre,",
				"          fecha_entrega,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega",
				"     )) ~> sink1"
			]
		}
	}
}