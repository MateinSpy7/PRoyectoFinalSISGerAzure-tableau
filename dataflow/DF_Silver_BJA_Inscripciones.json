{
	"name": "DF_Silver_BJA_Inscripciones",
	"properties": {
		"folder": {
			"name": "bronze_to_silver/BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_BJA_Inscripciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_BJA_Inscripciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(fecha_inscripcion = toDate(fecha_inscripcion, 'yyyy-MM-dd'),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          estado = upper(trim(estado))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          inscripcion_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          fecha_inscripcion,",
				"          semana_gestacion,",
				"          estado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          inscripcion_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          fecha_inscripcion,",
				"          semana_gestacion,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}