{
	"name": "DF_Silver_BJA_Partos",
	"properties": {
		"folder": {
			"name": "bronze_to_silver/BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_BJA_Partos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_BJA_Partos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          parto_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as string,",
				"          talla_nacimiento_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(fecha_parto = toDate(fecha_parto, 'yyyy-MM-dd'),",
				"          peso_nacimiento_kg = toDecimal(peso_nacimiento_kg),",
				"          talla_nacimiento_cm = toDecimal(talla_nacimiento_cm),",
				"          tipo_parto = upper(trim(tipo_parto))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          parto_id,",
				"          ci_madre,",
				"          ci_recien_nacido,",
				"          establecimiento_id,",
				"          fecha_parto,",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          parto_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as date,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(18,2),",
				"          talla_nacimiento_cm as decimal(18,2),",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          parto_id,",
				"          ci_madre,",
				"          ci_recien_nacido,",
				"          establecimiento_id,",
				"          fecha_parto,",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm",
				"     )) ~> sink1"
			]
		}
	}
}