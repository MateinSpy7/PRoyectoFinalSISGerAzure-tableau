{
	"name": "DF_Silver_BJA_Pagos",
	"properties": {
		"folder": {
			"name": "bronze_to_silver/BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_BJA_Pagos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_BJA_Pagos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(fecha_pago = toDate(fecha_pago, 'yyyy-MM-dd'),",
				"          monto_bs = toDecimal(monto_bs),",
				"          estado_pago = upper(trim(estado_pago))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          pago_id,",
				"          ci_beneficiaria,",
				"          concepto_pago,",
				"          monto_bs,",
				"          fecha_pago,",
				"          estado_pago,",
				"          canal_pago,",
				"          nro_comprobante",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(18,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          pago_id,",
				"          ci_beneficiaria,",
				"          concepto_pago,",
				"          monto_bs,",
				"          fecha_pago,",
				"          estado_pago,",
				"          canal_pago,",
				"          nro_comprobante",
				"     )) ~> sink1"
			]
		}
	}
}