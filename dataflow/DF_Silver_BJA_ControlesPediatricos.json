{
	"name": "DF_Silver_BJA_ControlesPediatricos",
	"properties": {
		"folder": {
			"name": "bronze_to_silver/BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_BJA_ControlesPediatricos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_BJA_ControlesPediatricos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          peso_nino_kg as string,",
				"          talla_nino_cm as string,",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(fecha_control = toDate(fecha_control, 'yyyy-MM-dd'),",
				"          nro_control = toInteger(nro_control),",
				"          peso_nino_kg = toDecimal(peso_nino_kg),",
				"          talla_nino_cm = toDecimal(talla_nino_cm),",
				"          resultado = upper(trim(resultado))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          control_pediatrico_id,",
				"          ci_nino,",
				"          ci_madre,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          peso_nino_kg,",
				"          talla_nino_cm,",
				"          vacuna_aplicada,",
				"          resultado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          peso_nino_kg as decimal(18,2),",
				"          talla_nino_cm as decimal(18,2),",
				"          vacuna_aplicada as string,",
				"          resultado as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_pediatrico_id,",
				"          ci_nino,",
				"          ci_madre,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          peso_nino_kg,",
				"          talla_nino_cm,",
				"          vacuna_aplicada,",
				"          resultado",
				"     )) ~> sink1"
			]
		}
	}
}